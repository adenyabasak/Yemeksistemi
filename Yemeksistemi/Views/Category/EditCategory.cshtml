@model Yemeksistemi.Models.Category

@{
    ViewData["Title"] = "Kategori Güncelle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">

    <h1 class="h3 mb-4 text-gray-800">Kategori Güncelle</h1>

    <div class="card shadow mb-4">

        <div class="card-body">

            <form asp-action="EditCategory" method="post">

                <input asp-for="CategoryId" type="hidden" />

                <div class="mb-3">
                    <label asp-for="CategoryName" class="form-label">Kategori Adı</label>
                    <input asp-for="CategoryName" class="form-control" />
                </div>

                <button type="submit" class="btn btn-warning">
                    Güncelle
                </button>

                <a href="/Category/Index" class="btn btn-secondary">
                    İptal
                </a>

            </form>

        </div>

    </div>

</div>