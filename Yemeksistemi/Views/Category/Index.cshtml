@model List<Yemeksistemi.Models.Category>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">

    <h1 class="h3 mb-4 text-gray-800">Kategoriler</h1>

    <form method="get">
        <input type="text" name="p" placeholder="Kategori ara..." />
        <button class="btn btn-primary btn-sm">Ara</button>
    </form>

    <br />

    <a href="/Category/AddCategory" class="btn btn-primary mb-3">
        + Yeni Kategori
    </a>

    <div class="card shadow mb-4">

        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
                Kategori Listesi
            </h6>
        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Kategori Adı</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.CategoryId</td>
                                <td>@item.CategoryName</td>

                                <td>

                                    <a href="/Category/DeleteCategory/@item.CategoryId"
                                       class="btn btn-danger btn-sm">
                                        Sil
                                    </a>

                                    <a href="@Url.Action("EditCategory", "Category", new { id = item.CategoryId })"
                                       class="btn btn-warning btn-sm">
                                        Güncelle
                                    </a>

                                </td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<p style="color:red;">TEST: @Model.Count</p>